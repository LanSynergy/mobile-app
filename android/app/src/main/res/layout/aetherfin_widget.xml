<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#1A1A2E"
    android:clipChildren="true">

    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_note"
        android:background="@drawable/bg_widget_art"
        android:contentDescription="Album Art" />

    <LinearLayout
        android:id="@+id/widget_text_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="70dp"
        android:layout_marginEnd="180dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not Playing"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aetherfin"
            android:textColor="#999999"
            android:textSize="13sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="4dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/widget_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_widget_prev"
            android:contentDescription="Previous" />

        <ImageButton
            android:id="@+id/widget_play_pause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_widget_play"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_widget_next"
            android:contentDescription="Next" />

        <ImageButton
            android:id="@+id/widget_favorite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_widget_heart"
            android:contentDescription="Favorite" />
    </LinearLayout>

</FrameLayout>
