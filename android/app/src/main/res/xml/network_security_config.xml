<?xml version="1.0" encoding="utf-8"?>
<!--
  Aetherfin is a personal-music-server client. Users routinely point it
  at LAN Jellyfin instances over plain HTTP (e.g. http://server.local:8096,
  http://192.168.1.50:8097), so cleartext traffic must be permitted.

  Android's `<domain>` matcher does NOT support CIDR ranges, only exact
  IP / hostname strings, which makes a narrow allowlist for the entire
  RFC 1918 space impractical. We open cleartext globally here.

  Trust anchors keep the system CA store for HTTPS traffic. We do NOT
  trust user-installed certs by default (that would let a malicious MITM
  cert intercept HTTPS Jellyfin servers).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
