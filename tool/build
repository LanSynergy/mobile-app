#!/usr/bin/env bash
# tool/build — Unified Aetherfin build script
#
# Handles the full build lifecycle:
#   deps → codegen → analyze → test → build → sign → rename → notify
#
# Called by CI (.github/workflows/build-apk.yml / release.yml / pr-checks.yml)
# or used directly for local development builds.
#
# Usage:  tool/build [options]
#
# Options:
#   --mode <mode>         Build mode: release|debug|profile (default: release)
#   --split-per-abi       Build per-ABI split APKs (smaller per-device APKs)
#   --no-universal        Skip universal APK when using --split-per-abi (CI only)
#   --sign                Sign APK (reads env: KEYSTORE_B64, STORE_PASSWORD,
#                         KEY_ALIAS, KEY_PASSWORD)
#   --install             Install APK on connected device after build
#   --skip-analyze        Skip flutter analyze
#   --skip-test           Skip flutter test
#   --skip-codegen        Skip dart run build_runner (code generation)
#   --skip-build          Skip the APK build step entirely (useful for PR checks)
#   --skip-build-id       Skip build ID generation
#   --help                Show this help
#
# Environment:
#   FLUTTER_HOME          Flutter SDK root (optional; defaults to PATH)
#   KEYSTORE_B64          Base64-encoded Android keystore (for --sign)
#   STORE_PASSWORD        Keystore password
#   KEY_ALIAS             Signing key alias
#   KEY_PASSWORD          Signing key password
#
set -euo pipefail

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------
MODE="release"
SPLIT_PER_ABI=false
BUILD_UNIVERSAL=true
INSTALL=false
SKIP_ANALYZE=false
SKIP_TEST=false
SKIP_CODEGEN=false
SKIP_BUILD=false
SKIP_BUILD_ID=false
SIGN=false
BUILD_ID=""
SHARD_INDEX=""
TOTAL_SHARDS=""

# Resolve Flutter / Dart commands
if [ -n "${FLUTTER_HOME:-}" ]; then
  FLUTTER="$FLUTTER_HOME/bin/flutter"
  DART="$FLUTTER_HOME/bin/dart"
else
  FLUTTER="flutter"
  DART="dart"
fi

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OUTDIR="$ROOT/build/app/outputs/flutter-apk"
CI_MODE="${GITHUB_ACTIONS:-false}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
usage() {
  sed -n '3,36p' "$0" | sed 's/^# //; s/^#$//; s/^#//'
  exit 0
}

print_banner() {
  echo ""
  echo "  ╔══════════════════════════════════════════╗"
  echo "  ║         Aetherfin Build Script           ║"
  echo "  ╚══════════════════════════════════════════╝"
  echo ""
}

warn()  { echo "  ⚠ $*" 1>&2; }
die()   { echo "  ✕ $*" 1>&2; exit 1; }

# Run a named step with CI collapsible groups.
step() {
  local name="$1"
  shift

  echo ""
  if [ "$CI_MODE" = "true" ]; then
    echo "::group::⏵ $name"
  fi
  echo "────────────────────────────────────────"
  echo "  $name"
  echo "────────────────────────────────────────"

  "$@"
  local rc=$?

  if [ "$CI_MODE" = "true" ]; then
    echo "::endgroup::"
  fi
  echo ""
  return $rc
}

# ---------------------------------------------------------------------------
# Trap — cleanup on exit
# ---------------------------------------------------------------------------
cleanup() {
  local rc=$?
  # Cleanup if needed
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# APK rename helper (runs in current shell)
# ---------------------------------------------------------------------------
rename_apks() {
  local outdir="$1"
  local version="$2"
  local build_id="$3"
  local mode="$4"
  local split="$5"

  cd "$outdir" || return 1
  shopt -s nullglob
  local renamed=0

  for f in app-*.apk; do
    local stem="${f#app-}"
    stem="${stem%.apk}"
    local abi_part="${stem%-$mode}"
    local newname
    if [ "$split" = "true" ] && [ -n "$abi_part" ] && [ "$abi_part" != "$stem" ]; then
      newname="Aetherfin-v${version}-${abi_part}-${build_id}.apk"
    else
      newname="Aetherfin-v${version}-${build_id}.apk"
    fi
    if [ "$f" != "$newname" ]; then
      echo "    $f → $newname"
      mv "$f" "$newname"
    fi
    renamed=$((renamed + 1))
  done
  echo "  Renamed $renamed APK(s)"
}

# ---------------------------------------------------------------------------
# Print summary
# ---------------------------------------------------------------------------
print_summary() {
  local outdir="$1"
  local mode="$2"
  local build_id="$3"
  local version="$4"

  echo ""
  echo "────────────────────────────────────────"
  echo "  ✅ Build complete"
  echo ""
  echo "  Mode:       $mode"
  echo "  Build ID:   $build_id"
  echo "  Split ABI:  $SPLIT_PER_ABI"
  echo "  Sign:       $SIGN"
  echo ""

  local count=0
  for f in "$outdir"/Aetherfin-v*.apk; do
    if [ -f "$f" ]; then
      local size
      size=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null || echo 0)
      local human
      human=$(numfmt --to=iec --suffix=B "$size" 2>/dev/null || echo "$size bytes")
      echo "  • $(basename "$f") ($human)"
      count=$((count + 1))
    fi
  done

  if [ "$count" -eq 0 ]; then
    echo "  (no APK files found in $outdir)"
  fi

  echo ""

  # GitHub Actions step summary
  if [ "$CI_MODE" = "true" ]; then
    {
      echo "## ✅ Aetherfin Build Summary"
      echo ""
      echo "| Property | Value |"
      echo "|----------|-------|"
      echo "| Mode | $mode |"
      echo "| Build ID | $build_id |"
      echo "| Split ABI | $SPLIT_PER_ABI |"
      echo "| Signed | $SIGN |"
      echo ""
      echo "### APKs"
      echo ""
      for f in "$outdir"/Aetherfin-v*.apk; do
        if [ -f "$f" ]; then
          local size
          size=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null || echo 0)
          local human
          human=$(numfmt --to=iec --suffix=B "$size" 2>/dev/null || echo "$size bytes")
          echo "- \`$(basename "$f")\` ($human)"
        fi
      done
    } >> "$GITHUB_STEP_SUMMARY"
  fi
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode)           MODE="$2"; shift 2 ;;
    --release)        MODE="release"; shift ;;
    --debug)          MODE="debug"; shift ;;
    --profile)        MODE="profile"; shift ;;
    --split-per-abi)  SPLIT_PER_ABI=true; shift ;;
    --no-universal)   BUILD_UNIVERSAL=false; shift ;;
    --sign)           SIGN=true; shift ;;
    --install)        INSTALL=true; shift ;;
    --skip-analyze)   SKIP_ANALYZE=true; shift ;;
    --skip-test)      SKIP_TEST=true; shift ;;
    --shard-index)    SHARD_INDEX="$2"; shift 2 ;;
    --total-shards)   TOTAL_SHARDS="$2"; shift 2 ;;
    --shard-index=*)  SHARD_INDEX="${1#*=}"; shift ;;
    --total-shards=*) TOTAL_SHARDS="${1#*=}"; shift ;;
    --skip-codegen)   SKIP_CODEGEN=true; shift ;;
    --skip-build)     SKIP_BUILD=true; shift ;;
    --skip-build-id)  SKIP_BUILD_ID=true; shift ;;
    --help)           usage ;;
    *)                die "Unknown option: $1. Use --help for usage." ;;
  esac
done

case "$MODE" in
  release|debug|profile) ;;
  *) die "Invalid mode: $MODE. Must be release, debug, or profile." ;;
esac

# ---------------------------------------------------------------------------
# Setup
# ---------------------------------------------------------------------------
mkdir -p "$(dirname "$TG_MSG_FILE")" "$OUTDIR"
cd "$ROOT"

# In CI, skip banner + toolchain — saves ~5-10s per run.
if [ "$CI_MODE" = "true" ] && { [ "$SKIP_BUILD" = "true" ] || [ "$SKIP_ANALYZE" = "true" ] || [ "$SKIP_TEST" = "true" ]; }; then
  echo ""
  echo "  CI mode — skipping banner, toolchain"
  echo "  Mode: $MODE | Analyze: $SKIP_ANALYZE | Test: $SKIP_TEST | Build: $SKIP_BUILD"
  echo ""
else
  print_banner
  echo "  Mode:          $MODE"
  echo "  Split ABI:     $SPLIT_PER_ABI"
  echo "  Sign:          $SIGN"
  echo "  Skip build:    $SKIP_BUILD"
  echo "  CI mode:       $CI_MODE"
  echo ""
fi

# ---------------------------------------------------------------------------
# 1. Toolchain versions
# ---------------------------------------------------------------------------
if [ "$CI_MODE" = "true" ]; then
  echo "  (toolchain skipped — set up by CI action)"
else
  step "Toolchain versions" bash -c "
    echo '  Flutter:'
    $FLUTTER --version 2>&1 | head -2
    echo ''
    echo '  Dart:'
    $DART --version 2>&1 | head -1
    echo ''
    echo '  Java:'
    java -version 2>&1 | head -1
  "
fi

# ---------------------------------------------------------------------------
# 2. Dependencies
# ---------------------------------------------------------------------------
step "Install dependencies" $FLUTTER pub get

# ---------------------------------------------------------------------------
# 3. Build ID
# ---------------------------------------------------------------------------
if [ "$SKIP_BUILD_ID" = "false" ] && [ "$SKIP_BUILD" = "false" ]; then
  step "Generate build ID" $DART run tool/generate_build_id.dart
fi

# Read build ID and version for later steps
if [ -f "$ROOT/lib/build_id.dart" ]; then
  BUILD_ID=$(grep "kBuildId" "$ROOT/lib/build_id.dart" | sed "s/.*'\(.*\)'.*/\1/")
else
  BUILD_ID="local"
fi
export TG_BUILD_ID="$BUILD_ID"
VERSION=$(awk '/^version:/ {print $2}' pubspec.yaml | cut -d+ -f1)
echo "  Build ID:    $BUILD_ID"
echo "  Version:     $VERSION"

# ---------------------------------------------------------------------------
# 4. Code generation
# ---------------------------------------------------------------------------
if [ "$SKIP_CODEGEN" = "false" ]; then
  step "Run code generation" $DART run build_runner build
fi

# ---------------------------------------------------------------------------
# 5. Static analysis
# ---------------------------------------------------------------------------
if [ "$SKIP_ANALYZE" = "false" ]; then
  step "Static analysis" $FLUTTER analyze --no-fatal-infos
fi

# ---------------------------------------------------------------------------
# 6. Tests
# ---------------------------------------------------------------------------
if [ "$SKIP_TEST" = "false" ]; then
  TEST_CMD="$FLUTTER test"
  if [ -n "$SHARD_INDEX" ] && [ -n "$TOTAL_SHARDS" ]; then
    TEST_CMD="$TEST_CMD --shard-index=$SHARD_INDEX --total-shards=$TOTAL_SHARDS"
    step "Unit tests (shard $SHARD_INDEX/$TOTAL_SHARDS)" $TEST_CMD
  else
    step "Unit tests" $TEST_CMD
  fi
fi

# ---------------------------------------------------------------------------
# 7. Signing (release mode only)
# ---------------------------------------------------------------------------
if [ "$SIGN" = "true" ]; then
  echo ""
  echo "────────────────────────────────────────"
  echo "  Configure signing"
  echo "────────────────────────────────────────"
  if [ -n "${KEYSTORE_B64:-}" ]; then
    echo "$KEYSTORE_B64" | base64 -d > "$ROOT/android/app/aetherfin-release.jks"
    cat > "$ROOT/android/key.properties" <<EOF
storeFile=aetherfin-release.jks
storePassword=$STORE_PASSWORD
keyAlias=$KEY_ALIAS
keyPassword=$KEY_PASSWORD
EOF
    echo "  ✅ Keystore decoded ($(wc -c < "$ROOT/android/app/aetherfin-release.jks") bytes)"
  else
    echo "  ⚠ KEYSTORE_B64 not set — building unsigned APK."
  fi
  echo ""
fi

# ---------------------------------------------------------------------------
# 8. Build APK
# ---------------------------------------------------------------------------
if [ "$SKIP_BUILD" = "false" ]; then
  if [ "$BUILD_UNIVERSAL" = "true" ]; then
    step "Build universal APK" bash -c "
    echo '  Running: flutter build apk --$MODE'
    (cd '$ROOT/android' && ./gradlew --stop) 2>/dev/null || true
    $FLUTTER build apk '--$MODE'
    "
  fi

  if [ "$SPLIT_PER_ABI" = "true" ]; then
    step "Build per-ABI APKs" bash -c "
    echo '  Running: flutter build apk --$MODE --split-per-abi'
    (cd '$ROOT/android' && ./gradlew --stop) 2>/dev/null || true
    $FLUTTER build apk '--$MODE' '--split-per-abi'
    "
  fi
fi

# ---------------------------------------------------------------------------
# 9. Rename APKs with standard naming
# ---------------------------------------------------------------------------
echo ""
echo "────────────────────────────────────────"
echo "  Rename APKs"
echo "────────────────────────────────────────"
if [ "$SKIP_BUILD" = "false" ]; then
  rename_apks "$OUTDIR" "$VERSION" "$BUILD_ID" "$MODE" "$SPLIT_PER_ABI"
else
  echo "  (skipped — no APK was built)"
fi
echo ""

# ---------------------------------------------------------------------------
# 10. Summary
# ---------------------------------------------------------------------------
print_summary "$OUTDIR" "$MODE" "$BUILD_ID" "$VERSION"
